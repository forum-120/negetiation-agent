+                ServiceInfo.builder()
+                        .id("svc-007")
+                        .name("大模型微调服务")
+                        .description("基于企业私有数据对基础模型进行 LoRA 微调，交付专属领域模型")
+                        .askingPrice(350.0)
+                        .category("AI 平台")
